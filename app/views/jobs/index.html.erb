<% content_for :title, "Vagas" %>

<section class="grid gap-4 md:grid-cols-4">
  <div class="rounded-3xl border border-white/10 bg-white/5 p-5">
    <p class="text-sm text-slate-400">Ativas</p>
    <p class="mt-3 text-3xl font-extrabold text-white"><%= @counts[:active] %></p>
  </div>
  <div class="rounded-3xl border border-sky-300/15 bg-sky-400/10 p-5">
    <p class="text-sm text-sky-100/70">Novas</p>
    <p class="mt-3 text-3xl font-extrabold text-sky-50"><%= @counts[:new_match] %></p>
  </div>
  <div class="rounded-3xl border border-fuchsia-300/15 bg-fuchsia-400/10 p-5">
    <p class="text-sm text-fuchsia-100/70">Aplicadas</p>
    <p class="mt-3 text-3xl font-extrabold text-fuchsia-50"><%= @counts[:applied] %></p>
  </div>
  <div class="rounded-3xl border border-amber-300/15 bg-amber-400/10 p-5">
    <p class="text-sm text-amber-100/70">Borderline</p>
    <p class="mt-3 text-3xl font-extrabold text-amber-50"><%= @counts[:borderline] %></p>
  </div>
</section>

<section class="rounded-[2rem] border border-white/10 bg-slate-950/65 p-6 shadow-2xl shadow-slate-950/25">
  <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h1 class="text-3xl font-extrabold tracking-tight text-white">Radar de vagas</h1>
      <p class="text-sm text-slate-400">Filtros rápidos para navegar muita vaga sem perder o contexto.</p>
      <div class="mt-3 flex flex-wrap items-center gap-2">
        <span class="rounded-full px-3 py-1 text-xs font-semibold ring-1 <%= tone_class(@search_profile.sync_status_tone) %>"><%= @search_profile.sync_status_label %></span>
        <span class="text-xs text-slate-500"><%= @search_profile.sync_status_detail %></span>
      </div>
    </div>
  </div>

  <div data-testid="active-profile-summary" class="mt-5 grid gap-3 rounded-2xl border border-white/10 bg-white/[0.03] p-4 sm:grid-cols-3">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400"><%= @search_profile.active? ? "Perfil ativo" : "Perfil pausado" %></p>
      <p class="mt-1 text-sm font-bold text-white"><%= @search_profile.name %></p>
    </div>
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Janela</p>
      <p class="mt-1 text-sm font-bold text-white">Janela <%= SearchProfiles::Vocabulary.scan_window_label(@search_profile.scan_window_days) %></p>
    </div>
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Busca</p>
      <p class="mt-1 text-sm font-bold text-white">Busca <%= @search_profile.sync_status_label.downcase %></p>
    </div>
  </div>

  <% tab_query = request.query_parameters.except("page", "user_state").merge("search_profile_id" => @search_profile.id) %>
  <% tabs = [["Novas", "new_match"], ["Todas", "all"], ["Vistas", "seen"], ["Aplicadas", "applied"], ["Ignoradas", "ignored"]] %>
  <div class="mt-6 flex flex-wrap gap-2">
    <% tabs.each do |label, state| %>
      <% active = (@filters[:user_state] || "new_match") == state %>
      <%= link_to label, jobs_path(tab_query.merge("user_state" => state)), class: "rounded-full px-4 py-2 text-sm font-semibold transition #{active ? 'bg-white text-slate-950' : 'border border-white/10 text-slate-300 hover:bg-white/5 hover:text-white'}" %>
    <% end %>
  </div>

  <%= form_with url: jobs_path, method: :get, **submit_state_form_options(default_loading_text: "Filtrando...", class: "mt-6 grid gap-4 md:grid-cols-6 xl:grid-cols-9") do |form| %>
    <div class="md:col-span-2">
      <%= form.label :search_profile_id, "Perfil", class: "text-xs font-semibold uppercase tracking-[0.18em] text-slate-400" %>
      <%= form.select :search_profile_id, options_for_select(@search_profiles.map { |profile| [profile.name, profile.id] }, @search_profile.id), {}, class: "mt-2 w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white" %>
    </div>
    <div class="md:col-span-2">
      <%= form.label :q, "Busca", class: "text-xs font-semibold uppercase tracking-[0.18em] text-slate-400" %>
      <%= form.text_field :q, value: @filters[:q], placeholder: "Titulo, empresa ou motivo", class: "mt-2 w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white placeholder:text-slate-500" %>
    </div>
    <div>
      <%= form.label :stack, "Stack", class: "text-xs font-semibold uppercase tracking-[0.18em] text-slate-400" %>
      <%= form.select :stack, options_for_select([["Todas", ""]] + @stack_options.map { |stack| [stack.titleize, stack] }, @filters[:stack]), {}, class: "mt-2 w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white" %>
    </div>
    <div>
      <%= form.label :match_strength, "Match", class: "text-xs font-semibold uppercase tracking-[0.18em] text-slate-400" %>
      <%= form.select :match_strength, options_for_select([["Todos", "all"], ["Forte", "strong"], ["Borderline", "borderline"]], @filters[:match_strength] || "all"), {}, class: "mt-2 w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white" %>
    </div>
    <div>
      <%= form.label :source, "Fonte", class: "text-xs font-semibold uppercase tracking-[0.18em] text-slate-400" %>
      <%= form.select :source, options_for_select([["Todas", ""]] + @source_options.map { |source| [source.name, source.slug] }, @filters[:source]), {}, class: "mt-2 w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white" %>
    </div>
    <div>
      <%= form.label :contract_type, "Contrato", class: "text-xs font-semibold uppercase tracking-[0.18em] text-slate-400" %>
      <%= form.select :contract_type, options_for_select([["Todos", "all"], ["CLT", "clt"], ["PJ", "pj"], ["CLT ou PJ", "clt_or_pj"], ["Sem sinal", "unknown"]], @filters[:contract_type] || "all"), {}, class: "mt-2 w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white" %>
    </div>
    <div>
      <%= form.label :user_state, "Status", class: "text-xs font-semibold uppercase tracking-[0.18em] text-slate-400" %>
      <%= form.select :user_state, options_for_select([["Todos", "all"], ["Nova", "new_match"], ["Vista", "seen"], ["Aplicada", "applied"], ["Ignorada", "ignored"]], @filters[:user_state] || "all"), {}, class: "mt-2 w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white" %>
    </div>
    <div>
      <%= form.label :title_language, "Idioma", class: "text-xs font-semibold uppercase tracking-[0.18em] text-slate-400" %>
      <%= form.select :title_language, options_for_select(@title_language_options, @filters[:title_language] || "all"), {}, class: "mt-2 w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white" %>
    </div>
    <div>
      <%= form.label :lifecycle_state, "Ciclo", class: "text-xs font-semibold uppercase tracking-[0.18em] text-slate-400" %>
      <%= form.select :lifecycle_state, options_for_select([["Ativas", "active"], ["Expiradas", "expired"], ["Tudo", "all"]], @filters[:lifecycle_state] || "active"), {}, class: "mt-2 w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white" %>
    </div>
    <div>
      <%= form.label :recency, "Recencia", class: "text-xs font-semibold uppercase tracking-[0.18em] text-slate-400" %>
      <%= form.select :recency, options_for_select([["Ativas", ""], ["24h", "24h"], ["7 dias", "7d"], ["14 dias", "14d"], ["30 dias", "30d"], ["Tudo", "all"]], @filters[:recency]), {}, class: "mt-2 w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white" %>
    </div>
    <div>
      <%= form.label :sort, "Ordenacao", class: "text-xs font-semibold uppercase tracking-[0.18em] text-slate-400" %>
      <%= form.select :sort, options_for_select([["Mais recentes", "newest"], ["Maior score", "score"], ["Atualizadas", "updated"], ["Empresa", "company"]], @filters[:sort] || "newest"), {}, class: "mt-2 w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white" %>
    </div>
    <div class="flex gap-3 md:col-span-6 xl:col-span-9">
      <%= form.submit "Filtrar", **submit_state_submit_options(loading_text: "Filtrando...", class: "rounded-2xl bg-sky-400 px-5 py-3 text-sm font-bold text-slate-950 transition hover:bg-sky-300") %>
      <%= link_to "Limpar", jobs_path, class: "rounded-2xl border border-white/10 px-5 py-3 text-sm font-semibold text-slate-200 transition hover:bg-white/5" %>
    </div>
  <% end %>

  <% first_visible_result = @total_matches.zero? ? 0 : ((@page - 1) * @per_page) + 1 %>
  <% last_visible_result = [ @page * @per_page, @total_matches ].min %>
  <div data-testid="filtered-results-summary" class="mt-6 flex flex-col gap-3 rounded-2xl border border-sky-300/20 bg-sky-400/10 p-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-100/70">Resultado do filtro</p>
      <p class="mt-1 text-2xl font-extrabold text-white"><%= pluralize(@total_matches, "vaga retornada", "vagas retornadas") %></p>
    </div>
    <p class="text-sm font-semibold text-sky-50">
      <% if @total_matches.positive? %>
        Mostrando <span class="text-white"><%= first_visible_result %>-<%= last_visible_result %></span> nesta pagina.
      <% else %>
        Nenhum item para este recorte.
      <% end %>
    </p>
  </div>
</section>

<section class="overflow-hidden rounded-[2rem] border border-white/10 bg-slate-950/65 shadow-2xl shadow-slate-950/25">
  <div data-testid="mobile-job-list" class="grid gap-4 p-4 md:hidden">
    <% if @job_matches.any? %>
      <% @job_matches.each do |job_match| %>
        <% job = job_match.job %>
        <article class="rounded-2xl border border-white/10 bg-white/[0.03] p-4">
          <div class="space-y-3">
            <div>
              <%= link_to job.title, job_path(job, search_profile_id: @search_profile.id), class: "text-base font-bold text-white hover:text-sky-200" %>
              <p class="mt-1 text-sm text-slate-300"><%= job.company_name %></p>
            </div>

            <div class="flex flex-wrap gap-2">
              <span class="rounded-full px-3 py-1 text-xs font-semibold ring-1 <%= tone_class(job_match.match_strength.to_sym) %>"><%= match_label(job_match) %></span>
              <span class="rounded-full px-3 py-1 text-xs font-semibold ring-1 <%= tone_class(job.lifecycle_state.to_sym) %>"><%= lifecycle_label(job) %></span>
              <span class="rounded-full px-3 py-1 text-xs font-semibold ring-1 <%= tone_class(job_match.user_state == "applied" ? :applied : job_match.user_state == "ignored" ? :ignored : :active) %>"><%= user_state_label(job_match) %></span>
              <span class="rounded-full px-3 py-1 text-xs font-semibold ring-1 <%= tone_class(contract_type_tone(job)) %>"><%= contract_type_label(job) %></span>
            </div>

            <p class="text-sm leading-6 text-slate-400"><%= job_match.reason %></p>

            <dl class="grid gap-3 text-sm text-slate-300">
              <div>
                <dt class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Stack</dt>
                <dd class="mt-2 flex flex-wrap gap-2">
                  <% job_match.stack_tags.each do |tag| %>
                    <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-semibold text-slate-200"><%= tag %></span>
                  <% end %>
                </dd>
              </div>
              <div>
                <dt class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Remoto</dt>
                <dd class="mt-1"><%= job.remote_text.presence || job.location_text.presence || "Sem sinal" %></dd>
              </div>
              <div>
                <dt class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Fonte</dt>
                <dd class="mt-1">
                  <span class="font-semibold text-white"><%= job.job_source_name %></span>
                  <span class="text-slate-500">· <%= job.job_source_host %></span>
                </dd>
              </div>
              <div>
                <dt class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Sinal</dt>
                <dd class="mt-1"><%= radar_seen_label(job_match) %></dd>
                <dd class="mt-1 text-xs text-slate-400"><%= publication_signal_label(job) %> · Score <%= job_match.score %></dd>
              </div>
            </dl>

            <div class="flex flex-wrap gap-2 pt-1">
              <%= render "job_match_actions", job:, search_profile: @search_profile %>
            </div>
          </div>
        </article>
      <% end %>
    <% else %>
      <div class="px-2 py-10 text-center">
        <% if @has_any_matches %>
          <p class="text-base font-semibold text-white">Nenhuma vaga nova nesse recorte.</p>
          <p class="mt-2 text-sm text-slate-400">A aba principal mostra apenas vagas nao vistas e nao aplicadas. Troque para "Todas" ou outro status para revisar o historico.</p>
        <% else %>
          <p class="text-base font-semibold text-white">Nenhuma vaga ingerida ainda.</p>
          <p class="mt-2 text-sm text-slate-400">Assim que o primeiro run do Rails ou uma ingestao complementar terminar, a lista aparecera aqui com filtros, score e links diretos.</p>
        <% end %>
      </div>
    <% end %>
  </div>

  <div data-testid="desktop-job-table" class="hidden overflow-x-auto md:block">
    <table class="min-w-full divide-y divide-white/10 text-sm">
      <thead class="bg-white/5 text-left text-xs uppercase tracking-[0.2em] text-slate-400">
        <tr>
          <th class="px-6 py-4">Vaga</th>
          <th class="px-6 py-4">Stack</th>
          <th class="px-6 py-4">Remoto</th>
          <th class="px-6 py-4">Contrato</th>
          <th class="px-6 py-4">Fonte</th>
          <th class="px-6 py-4">Sinal</th>
          <th class="px-6 py-4">Acoes</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-white/5">
        <% if @job_matches.any? %>
          <% @job_matches.each do |job_match| %>
            <% job = job_match.job %>
            <tr class="align-top">
              <td class="px-6 py-5">
                <div class="space-y-3">
                  <div>
                    <%= link_to job.title, job_path(job, search_profile_id: @search_profile.id), class: "text-base font-bold text-white hover:text-sky-200" %>
                    <p class="mt-1 text-sm text-slate-300"><%= job.company_name %></p>
                  </div>
                  <div class="flex flex-wrap gap-2">
                    <span class="rounded-full px-3 py-1 text-xs font-semibold ring-1 <%= tone_class(job_match.match_strength.to_sym) %>"><%= match_label(job_match) %></span>
                    <span class="rounded-full px-3 py-1 text-xs font-semibold ring-1 <%= tone_class(job.lifecycle_state.to_sym) %>"><%= lifecycle_label(job) %></span>
                    <span class="rounded-full px-3 py-1 text-xs font-semibold ring-1 <%= tone_class(job_match.user_state == "applied" ? :applied : job_match.user_state == "ignored" ? :ignored : :active) %>"><%= user_state_label(job_match) %></span>
                    <% job_match.eligibility_flags.each do |flag| %>
                      <span class="rounded-full border border-fuchsia-300/20 bg-fuchsia-400/10 px-3 py-1 text-xs font-semibold text-fuchsia-100"><%= flag.humanize %></span>
                    <% end %>
                  </div>
                  <p class="max-w-xl text-sm leading-6 text-slate-400"><%= job_match.reason %></p>
                </div>
              </td>
              <td class="px-6 py-5">
                <div class="flex max-w-xs flex-wrap gap-2">
                  <% job_match.stack_tags.each do |tag| %>
                    <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-semibold text-slate-200"><%= tag %></span>
                  <% end %>
                </div>
              </td>
              <td class="px-6 py-5 text-slate-300"><%= job.remote_text.presence || job.location_text.presence || "Sem sinal" %></td>
              <td class="px-6 py-5">
                <span class="rounded-full px-3 py-1 text-xs font-semibold ring-1 <%= tone_class(contract_type_tone(job)) %>"><%= contract_type_label(job) %></span>
              </td>
              <td class="px-6 py-5">
                <p class="font-semibold text-white"><%= job.job_source_name %></p>
                <p class="mt-1 text-xs text-slate-500"><%= job.job_source_host %></p>
              </td>
              <td class="px-6 py-5">
                <p class="font-semibold text-white"><%= radar_seen_label(job_match) %></p>
                <p class="mt-1 text-xs text-slate-400"><%= publication_signal_label(job) %></p>
                <p class="mt-1 text-xs text-slate-500">Score <%= job_match.score %></p>
              </td>
              <td class="px-6 py-5">
                <div class="flex min-w-[220px] flex-wrap gap-2">
                  <%= render "job_match_actions", job:, search_profile: @search_profile %>
                </div>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="7" class="px-6 py-12 text-center">
              <% if @has_any_matches %>
                <p class="text-base font-semibold text-white">Nenhuma vaga nova nesse recorte.</p>
                <p class="mt-2 text-sm text-slate-400">A aba principal mostra apenas vagas nao vistas e nao aplicadas. Troque para "Todas" ou outro status para revisar o historico.</p>
              <% else %>
                <p class="text-base font-semibold text-white">Nenhuma vaga ingerida ainda.</p>
                <p class="mt-2 text-sm text-slate-400">Assim que o primeiro run do Rails ou uma ingestao complementar terminar, a lista aparecera aqui com filtros, score e links diretos.</p>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="flex items-center justify-between border-t border-white/10 px-6 py-4">
    <p class="text-sm text-slate-400">Pagina <%= @page %> de <%= @total_pages %></p>
    <div class="flex items-center gap-2">
      <% pagination_window(@page, @total_pages).each do |page| %>
        <% query_params = request.query_parameters.merge(page: page, search_profile_id: @search_profile.id) %>
        <%= link_to page, jobs_path(query_params), class: "inline-flex h-10 w-10 items-center justify-center rounded-full text-sm font-bold #{page == @page ? 'bg-sky-400 text-slate-950' : 'border border-white/10 text-slate-200 hover:bg-white/5'}" %>
      <% end %>
    </div>
  </div>
</section>
