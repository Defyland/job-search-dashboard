<% content_for :title, @job.title %>

<section class="grid gap-6 lg:grid-cols-[1.15fr_0.85fr]">
  <article class="space-y-6 rounded-[2rem] border border-white/10 bg-slate-950/65 p-6 shadow-2xl shadow-slate-950/25 sm:p-8">
    <div class="space-y-4">
      <div class="flex flex-wrap gap-2">
        <span class="rounded-full px-3 py-1 text-xs font-semibold ring-1 <%= tone_class(@job_match.match_strength.to_sym) %>"><%= match_label(@job_match) %></span>
        <span class="rounded-full px-3 py-1 text-xs font-semibold ring-1 <%= tone_class(@job.lifecycle_state.to_sym) %>"><%= lifecycle_label(@job) %></span>
        <span class="rounded-full px-3 py-1 text-xs font-semibold ring-1 <%= tone_class(@job_match.user_state == "applied" ? :applied : @job_match.user_state == "ignored" ? :ignored : :active) %>"><%= user_state_label(@job_match) %></span>
        <% @job_match.eligibility_flags.each do |flag| %>
          <span class="rounded-full border border-fuchsia-300/20 bg-fuchsia-400/10 px-3 py-1 text-xs font-semibold text-fuchsia-100"><%= flag.humanize %></span>
        <% end %>
      </div>

      <div>
        <h1 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl"><%= @job.title %></h1>
        <p class="mt-2 text-lg text-slate-300"><%= @job.company_name %></p>
      </div>

      <p class="text-sm text-slate-400"><%= @detail_snapshot.source_snapshot_label %></p>
    </div>

    <section class="grid gap-4 rounded-[1.75rem] border border-sky-300/20 bg-sky-400/10 p-5">
      <div class="space-y-1">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-100/80">Por que deu match</p>
        <p class="text-base leading-7 text-sky-50"><%= @job_match.reason %></p>
      </div>

      <div class="grid gap-4 sm:grid-cols-3">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-100/70">Score</p>
          <p class="mt-1 text-2xl font-extrabold text-white"><%= @job_match.score %></p>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-100/70">Senioridade</p>
          <p class="mt-1 text-sm font-bold text-white"><%= @job_match.seniority %></p>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-100/70">Stack detectada</p>
          <div class="mt-2 flex flex-wrap gap-2">
            <% @job_match.stack_tags.each do |tag| %>
              <span class="rounded-full border border-white/10 bg-white/10 px-3 py-1 text-xs font-semibold text-white"><%= tag %></span>
            <% end %>
          </div>
        </div>
      </div>
    </section>

    <section class="space-y-4">
      <div class="flex flex-wrap items-end justify-between gap-3">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Descricao capturada</p>
          <h2 class="mt-1 text-xl font-bold text-white">Leia a vaga sem sair do radar</h2>
        </div>
        <% unless @detail_snapshot.description_available? %>
          <span class="rounded-full border border-amber-300/20 bg-amber-400/10 px-3 py-1 text-xs font-semibold text-amber-100">Descricao parcial</span>
        <% end %>
      </div>

      <div class="rounded-[1.75rem] border border-white/10 bg-white/[0.03] p-5 text-sm text-slate-200">
        <%= simple_format(@detail_snapshot.description_text, { class: "leading-7" }, wrapper_tag: "p") %>
      </div>
    </section>

    <div class="flex flex-wrap gap-3">
      <% if @job.safe_apply_url %>
        <%= button_to "Abrir candidatura", open_job_path(@job, search_profile_id: @search_profile.id), method: :post, form: { target: "_blank", rel: "noopener", data: { turbo: false }, class: "contents" }, class: "rounded-2xl bg-sky-400 px-5 py-3 text-sm font-extrabold uppercase tracking-[0.14em] text-slate-950" %>
      <% end %>
      <%= link_to "Voltar ao radar", jobs_path(search_profile_id: @search_profile.id, user_state: :all), class: "rounded-2xl border border-white/10 px-5 py-3 text-sm font-semibold text-slate-200 transition hover:bg-white/5" %>
      <%= button_to "Marcar como aplicada", mark_job_path(@job, search_profile_id: @search_profile.id, user_state: :applied), method: :patch, **submit_state_button_to_options(loading_text: "Atualizando...", class: "rounded-2xl border border-fuchsia-300/20 bg-fuchsia-400/10 px-5 py-3 text-sm font-semibold text-fuchsia-100") %>
      <%= button_to "Ignorar", mark_job_path(@job, search_profile_id: @search_profile.id, user_state: :ignored), method: :patch, **submit_state_button_to_options(loading_text: "Atualizando...", class: "rounded-2xl border border-white/10 px-5 py-3 text-sm font-semibold text-slate-200") %>
    </div>
  </article>

  <aside class="space-y-6">
    <section class="rounded-[2rem] border border-white/10 bg-slate-950/65 p-6 shadow-2xl shadow-slate-950/25">
      <h2 class="text-lg font-bold text-white">Resumo da vaga</h2>

      <div class="mt-5 grid gap-4">
        <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Requisitos</p>
          <% if @detail_snapshot.requirements.any? %>
            <ul class="mt-3 list-disc space-y-2 pl-5 text-sm leading-6 text-slate-200">
              <% @detail_snapshot.requirements.each do |item| %>
                <li><%= item %></li>
              <% end %>
            </ul>
          <% else %>
            <p class="mt-3 text-sm text-slate-400">Nenhum requisito explicito foi identificado no texto capturado.</p>
          <% end %>
        </div>

        <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Responsabilidades</p>
          <% if @detail_snapshot.responsibilities.any? %>
            <ul class="mt-3 list-disc space-y-2 pl-5 text-sm leading-6 text-slate-200">
              <% @detail_snapshot.responsibilities.each do |item| %>
                <li><%= item %></li>
              <% end %>
            </ul>
          <% else %>
            <p class="mt-3 text-sm text-slate-400">Nenhuma responsabilidade explicita foi identificada no texto capturado.</p>
          <% end %>
        </div>

        <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Beneficios e sinais</p>
          <% if @detail_snapshot.benefits.any? %>
            <ul class="mt-3 list-disc space-y-2 pl-5 text-sm leading-6 text-slate-200">
              <% @detail_snapshot.benefits.each do |item| %>
                <li><%= item %></li>
              <% end %>
            </ul>
          <% else %>
            <p class="mt-3 text-sm text-slate-400">Nenhum beneficio explicito foi identificado no texto capturado.</p>
          <% end %>
        </div>

        <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Sinais de atencao</p>
          <% if @detail_snapshot.attention_points.any? %>
            <ul class="mt-3 list-disc space-y-2 pl-5 text-sm leading-6 text-amber-100">
              <% @detail_snapshot.attention_points.each do |item| %>
                <li><%= item %></li>
              <% end %>
            </ul>
          <% else %>
            <p class="mt-3 text-sm text-slate-400">Nenhum sinal critico foi identificado localmente.</p>
          <% end %>
        </div>
      </div>
    </section>

    <section class="rounded-[2rem] border border-white/10 bg-slate-950/65 p-6 shadow-2xl shadow-slate-950/25">
      <h2 class="text-lg font-bold text-white">Origem e status</h2>
      <dl class="mt-4 grid gap-4 text-sm">
        <div>
          <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Fonte</dt>
          <dd class="mt-1 font-semibold text-white"><%= @job.job_source_name %></dd>
          <dd class="text-slate-500"><%= @job.job_source_host %></dd>
        </div>
        <div>
          <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Localidade</dt>
          <dd class="mt-1 text-slate-200"><%= @job.remote_text.presence || @job.location_text.presence || "Sem sinal" %></dd>
        </div>
        <div>
          <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Contrato</dt>
          <dd class="mt-2"><span class="rounded-full px-3 py-1 text-xs font-semibold ring-1 <%= tone_class(contract_type_tone(@job)) %>"><%= contract_type_label(@job) %></span></dd>
        </div>
        <div>
          <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Datas</dt>
          <dd class="mt-1 text-slate-300">Primeira vista: <%= l(@job_match.first_seen_at, format: :short) %></dd>
          <dd class="text-slate-300">Ultima vista: <%= l(@job_match.last_seen_at, format: :short) %></dd>
          <dd class="text-slate-300">Validada: <%= l(@job_match.last_validated_at, format: :short) %></dd>
        </div>
        <div>
          <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Link original</dt>
          <dd class="mt-2 break-words text-sky-100">
            <% if @job.safe_canonical_url %>
              <span><%= @job.canonical_url %></span>
              <% if @job.safe_apply_url %>
                <%= button_to "Abrir no site original", open_job_path(@job, search_profile_id: @search_profile.id), method: :post, form: { target: "_blank", rel: "noopener", data: { turbo: false }, class: "mt-3" }, class: "rounded-2xl border border-sky-300/20 bg-sky-400/10 px-4 py-2 text-xs font-semibold text-sky-100" %>
              <% end %>
            <% else %>
              <span class="text-slate-400">Link original indisponivel</span>
            <% end %>
          </dd>
        </div>
      </dl>
    </section>

    <section class="rounded-[2rem] border border-white/10 bg-slate-950/65 p-6 shadow-2xl shadow-slate-950/25">
      <h2 class="text-lg font-bold text-white">Historico de runs</h2>
      <div class="mt-4 space-y-3">
        <% @history.each do |item| %>
          <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
            <div class="flex items-center justify-between gap-3">
              <p class="font-semibold text-white"><%= item.outcome.humanize %></p>
              <p class="text-xs text-slate-500"><%= l(item.created_at, format: :short) %></p>
            </div>
            <% if item.search_run %>
              <p class="mt-1 text-xs uppercase tracking-[0.18em] text-slate-500">Run #<%= item.search_run.id %> · <%= item.search_run.window_label %></p>
            <% end %>
            <p class="mt-3 text-sm leading-6 text-slate-300"><%= item.reason %></p>
          </div>
        <% end %>
      </div>
    </section>

    <details class="rounded-[2rem] border border-white/10 bg-slate-950/65 p-6 shadow-2xl shadow-slate-950/25">
      <summary class="cursor-pointer text-lg font-bold text-white">Payload tecnico</summary>
      <pre class="mt-4 overflow-x-auto rounded-2xl bg-slate-950 p-4 text-xs leading-6 text-slate-300"><%= JSON.pretty_generate(@job.raw_payload) %></pre>
    </details>
  </aside>
</section>
