<% content_for :title, @job.title %>

<section class="grid gap-6 lg:grid-cols-[1.15fr_0.85fr]">
  <article class="space-y-6 rounded-[2rem] border border-white/10 bg-slate-950/65 p-8 shadow-2xl shadow-slate-950/25">
    <div class="space-y-4">
      <div class="flex flex-wrap gap-2">
        <span class="rounded-full px-3 py-1 text-xs font-semibold ring-1 <%= tone_class(@job.match_strength.to_sym) %>"><%= match_label(@job) %></span>
        <span class="rounded-full px-3 py-1 text-xs font-semibold ring-1 <%= tone_class(@job.lifecycle_state.to_sym) %>"><%= lifecycle_label(@job) %></span>
        <span class="rounded-full px-3 py-1 text-xs font-semibold ring-1 <%= tone_class(@job.user_state == "applied" ? :applied : @job.user_state == "ignored" ? :ignored : :active) %>"><%= user_state_label(@job) %></span>
      </div>

      <div>
        <h1 class="text-4xl font-extrabold tracking-tight text-white"><%= @job.title %></h1>
        <p class="mt-2 text-lg text-slate-300"><%= @job.company_name %></p>
      </div>

      <p class="max-w-3xl text-base leading-8 text-slate-300"><%= @job.reason %></p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      <div class="rounded-3xl border border-white/10 bg-white/5 p-4">
        <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Fonte</p>
        <p class="mt-2 font-semibold text-white"><%= @job.job_source_name %></p>
        <p class="text-sm text-slate-400"><%= @job.job_source_host %></p>
      </div>
      <div class="rounded-3xl border border-white/10 bg-white/5 p-4">
        <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Localidade</p>
        <p class="mt-2 font-semibold text-white"><%= @job.remote_text.presence || @job.location_text.presence || "Sem sinal" %></p>
        <p class="text-sm text-slate-400"><%= @job.posted_text.presence || "sem texto de recencia" %></p>
      </div>
      <div class="rounded-3xl border border-white/10 bg-white/5 p-4">
        <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Datas</p>
        <p class="mt-2 text-sm text-slate-300">Primeira vista: <%= l(@job.first_seen_at, format: :short) %></p>
        <p class="text-sm text-slate-300">Ultima vista: <%= l(@job.last_seen_at, format: :short) %></p>
        <p class="text-sm text-slate-300">Validada: <%= l(@job.last_validated_at, format: :short) %></p>
      </div>
      <div class="rounded-3xl border border-white/10 bg-white/5 p-4">
        <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Stack</p>
        <div class="mt-3 flex flex-wrap gap-2">
          <% @job.stack_tags.each do |tag| %>
            <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-semibold text-slate-200"><%= tag %></span>
          <% end %>
        </div>
      </div>
    </div>

    <div class="flex flex-wrap gap-3">
      <%= link_to "Abrir candidatura", @job.apply_url, target: "_blank", rel: "noreferrer", class: "rounded-2xl bg-sky-400 px-5 py-3 text-sm font-extrabold uppercase tracking-[0.14em] text-slate-950" %>
      <%= button_to "Marcar como aplicada", mark_job_path(@job, user_state: :applied), method: :patch, class: "rounded-2xl border border-fuchsia-300/20 bg-fuchsia-400/10 px-5 py-3 text-sm font-semibold text-fuchsia-100" %>
      <%= button_to "Ignorar", mark_job_path(@job, user_state: :ignored), method: :patch, class: "rounded-2xl border border-white/10 px-5 py-3 text-sm font-semibold text-slate-200" %>
    </div>
  </article>

  <aside class="space-y-6">
    <section class="rounded-[2rem] border border-white/10 bg-slate-950/65 p-6 shadow-2xl shadow-slate-950/25">
      <h2 class="text-lg font-bold text-white">Historico de runs</h2>
      <div class="mt-4 space-y-3">
        <% @history.each do |item| %>
          <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
            <div class="flex items-center justify-between gap-3">
              <p class="font-semibold text-white"><%= item.outcome.humanize %></p>
              <p class="text-xs text-slate-500"><%= l(item.created_at, format: :short) %></p>
            </div>
            <% if item.search_run %>
              <p class="mt-1 text-xs uppercase tracking-[0.18em] text-slate-500">Run #<%= item.search_run.id %> · <%= item.search_run.window_label %></p>
            <% end %>
            <p class="mt-3 text-sm leading-6 text-slate-300"><%= item.reason %></p>
          </div>
        <% end %>
      </div>
    </section>

    <section class="rounded-[2rem] border border-white/10 bg-slate-950/65 p-6 shadow-2xl shadow-slate-950/25">
      <h2 class="text-lg font-bold text-white">Payload bruto</h2>
      <pre class="mt-4 overflow-x-auto rounded-2xl bg-slate-950 p-4 text-xs leading-6 text-slate-300"><%= JSON.pretty_generate(@job.raw_payload) %></pre>
    </section>
  </aside>
</section>
