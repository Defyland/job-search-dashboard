<%= link_to "Detalhes", job_path(job, search_profile_id: search_profile.id), class: "rounded-full border border-sky-300/20 bg-sky-400/10 px-3 py-2 text-xs font-semibold text-sky-100" %>
<% if job.safe_apply_url %>
  <%= button_to "Abrir", open_job_path(job, search_profile_id: search_profile.id), method: :post, form: { target: "_blank", rel: "noopener", data: { turbo: false }, class: "contents" }, class: "rounded-full bg-white px-3 py-2 text-xs font-extrabold uppercase tracking-[0.14em] text-slate-950" %>
<% end %>
<%= button_to "Vista", mark_job_path(job, search_profile_id: search_profile.id, user_state: :seen), method: :patch, **submit_state_button_to_options(loading_text: "Atualizando...", class: "rounded-full border border-white/10 px-3 py-2 text-xs font-semibold text-slate-200") %>
<%= button_to "Aplicada", mark_job_path(job, search_profile_id: search_profile.id, user_state: :applied), method: :patch, **submit_state_button_to_options(loading_text: "Atualizando...", class: "rounded-full border border-fuchsia-300/20 bg-fuchsia-400/10 px-3 py-2 text-xs font-semibold text-fuchsia-100") %>
<%= button_to "Ignorar", mark_job_path(job, search_profile_id: search_profile.id, user_state: :ignored), method: :patch, **submit_state_button_to_options(loading_text: "Atualizando...", class: "rounded-full border border-white/10 px-3 py-2 text-xs font-semibold text-slate-400") %>
