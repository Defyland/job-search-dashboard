<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Job Search Dashboard" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Job Search Dashboard">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-[#07111f] text-slate-100">
    <div class="min-h-screen bg-[radial-gradient(circle_at_top_left,_rgba(56,189,248,0.18),_transparent_28%),radial-gradient(circle_at_top_right,_rgba(244,114,182,0.14),_transparent_24%),linear-gradient(180deg,_#081120_0%,_#0b1628_100%)]">
      <header class="sticky top-0 z-20 border-b border-white/10 bg-slate-950/75 backdrop-blur-xl">
        <div class="mx-auto flex max-w-7xl items-center justify-between gap-6 px-4 py-4 sm:px-6">
          <div>
            <%= link_to "Radar de Vagas", root_path, class: "text-xl font-extrabold tracking-tight text-white" %>
          </div>

          <% if current_user %>
            <nav class="hidden items-center gap-2 md:flex">
              <%= link_to "Vagas", jobs_path, class: "rounded-full px-4 py-2 text-sm font-medium #{current_page?(jobs_path) ? 'bg-white/10 text-white' : 'text-slate-300 hover:bg-white/5 hover:text-white'}" %>
              <%= link_to "Perfis", search_profiles_path, class: "rounded-full px-4 py-2 text-sm font-medium #{current_page?(search_profiles_path) ? 'bg-white/10 text-white' : 'text-slate-300 hover:bg-white/5 hover:text-white'}" %>
              <%= link_to "Runs", search_runs_path, class: "rounded-full px-4 py-2 text-sm font-medium #{current_page?(search_runs_path) ? 'bg-white/10 text-white' : 'text-slate-300 hover:bg-white/5 hover:text-white'}" %>
              <%= link_to "Fontes", sources_path, class: "rounded-full px-4 py-2 text-sm font-medium #{current_page?(sources_path) ? 'bg-white/10 text-white' : 'text-slate-300 hover:bg-white/5 hover:text-white'}" %>
            </nav>

            <div class="flex items-center gap-3">
              <div class="hidden text-right md:block">
                <p class="text-sm font-semibold text-white"><%= current_user.email_address %></p>
                <p class="text-xs text-slate-400">Acesso privado</p>
              </div>
              <%= button_to "Sair", session_path, method: :delete, **submit_state_button_to_options(loading_text: "Saindo...", class: "rounded-full border border-white/15 px-4 py-2 text-sm font-semibold text-white transition hover:border-white/30 hover:bg-white/5") %>
            </div>
          <% end %>
        </div>
      </header>

      <main class="mx-auto flex max-w-7xl flex-col gap-6 px-4 py-8 sm:px-6">
        <%= render "shared/flash" if flash.any? %>
        <%= yield %>
      </main>
    </div>
  </body>
</html>
