<% content_for :title, "Perfis" %>

<section class="rounded-[2rem] border border-white/10 bg-slate-950/65 shadow-2xl shadow-slate-950/25">
  <div class="flex flex-col gap-4 border-b border-white/10 px-6 py-5 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-3xl font-extrabold tracking-tight text-white">Perfis de busca</h1>
      <p class="mt-2 text-sm text-slate-400">Cada perfil define uma intencao de busca e recebe seus proprios matches.</p>
    </div>
    <%= link_to "Novo perfil", new_search_profile_path, class: "rounded-2xl bg-sky-400 px-5 py-3 text-sm font-bold text-slate-950 transition hover:bg-sky-300" %>
  </div>

  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-white/10 text-sm">
      <thead class="bg-white/5 text-left text-xs uppercase tracking-[0.2em] text-slate-400">
        <tr>
          <th class="px-6 py-4">Perfil</th>
          <th class="px-6 py-4">Stacks</th>
          <th class="px-6 py-4">Restricoes</th>
          <th class="px-6 py-4">Matches</th>
          <th class="px-6 py-4">Acoes</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-white/5">
        <% @search_profiles.each do |profile| %>
          <tr class="align-top">
            <td class="px-6 py-5">
              <p class="font-bold text-white"><%= profile.name %></p>
              <p class="mt-1 text-xs text-slate-500"><%= profile.active? ? "Ativo" : "Pausado" %> · <%= profile.scan_window_days %> dias</p>
              <p class="mt-2 text-xs font-semibold uppercase tracking-[0.14em] text-slate-400"><%= profile.language_scope_label %></p>
              <div class="mt-3 flex flex-wrap items-center gap-2">
                <span class="rounded-full px-3 py-1 text-xs font-semibold ring-1 <%= tone_class(profile.sync_status_tone) %>"><%= profile.sync_status_label %></span>
                <span class="text-xs text-slate-500"><%= profile.sync_status_detail %></span>
              </div>
            </td>
            <td class="px-6 py-5">
              <div class="flex max-w-sm flex-wrap gap-2">
                <% profile.target_stacks.each do |stack| %>
                  <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-semibold text-slate-200"><%= stack %></span>
                <% end %>
              </div>
            </td>
            <td class="px-6 py-5 text-slate-300">
              <p><%= profile.required_remote? ? "Exige remoto" : "Nao exige remoto" %></p>
              <p class="mt-1"><%= profile.include_women_only? ? "Inclui vagas exclusivas para mulheres" : "Exclui vagas exclusivas para mulheres" %></p>
            </td>
            <td class="px-6 py-5 text-slate-300"><%= profile.job_matches.count %></td>
            <td class="px-6 py-5">
              <div class="flex min-w-[220px] flex-wrap gap-2">
                <%= link_to "Abrir", jobs_path(search_profile_id: profile.id), class: "rounded-full bg-white px-3 py-2 text-xs font-extrabold uppercase tracking-[0.14em] text-slate-950" %>
                <%= link_to "Editar", edit_search_profile_path(profile), class: "rounded-full border border-white/10 px-3 py-2 text-xs font-semibold text-slate-200" %>
                <%= button_to "Remover", search_profile_path(profile), method: :delete, **submit_state_button_to_options(loading_text: "Removendo...", class: "rounded-full border border-white/10 px-3 py-2 text-xs font-semibold text-slate-400") %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
