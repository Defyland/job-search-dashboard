<% content_for :title, @onboarding_mode ? "Comecar perfil" : "Novo perfil" %>

<section class="rounded-[2rem] border border-white/10 bg-slate-950/65 p-6 shadow-2xl shadow-slate-950/25">
  <div class="mb-6">
    <h1 class="text-3xl font-extrabold tracking-tight text-white"><%= @onboarding_mode ? "Comece pelo essencial" : "Novo perfil" %></h1>
    <p class="mt-2 text-sm text-slate-400">
      <%= @onboarding_mode ? "O primeiro acesso precisa de poucos dados para o radar sair do zero." : "Configure a busca pelo que voce quer receber no radar." %>
    </p>
  </div>

  <%= render(@onboarding_mode ? "onboarding_form" : "form", search_profile: @search_profile) %>
</section>
