<% simple_input = @simple_profile_input || search_profile.simple_form_state %>
<% advanced_open = @advanced_open %>

<%= form_with model: search_profile, **submit_state_form_options(default_loading_text: "Processando...", class: "grid gap-6", data: { turbo: false }) do |form| %>
  <% if search_profile.errors.any? %>
    <div class="rounded-2xl border border-rose-400/30 bg-rose-500/10 p-4 text-sm text-rose-100">
      <p class="font-bold">Revise o perfil antes de salvar.</p>
      <ul class="mt-2 list-disc pl-5">
        <% search_profile.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if @compiled_profile_payload.present? %>
    <%= hidden_field_tag "search_profile[compiled_profile_payload]", @compiled_profile_payload %>
  <% end %>

  <section class="grid gap-5 rounded-[1.75rem] border border-white/10 bg-white/[0.03] p-5">
    <div class="space-y-1">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-200/70">Modo simples</p>
      <h2 class="text-xl font-bold text-white">Descreva a intencao do perfil</h2>
      <p class="text-sm text-slate-400">Informe a stack e as restricoes. O app gera titulos e aliases para o motor de match.</p>
    </div>

    <div class="grid gap-4 md:grid-cols-2">
      <div>
        <%= form.label :name, "Nome do perfil", class: "text-xs font-semibold uppercase tracking-[0.18em] text-slate-400" %>
        <%= form.text_field :name, value: simple_input["name"], class: "mt-2 w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white", placeholder: "Ex.: Senior Salesforce Remote BR/LatAm" %>
      </div>
      <div>
        <%= label_tag "search_profile_technology_intent", "Tecnologia / stack", class: "text-xs font-semibold uppercase tracking-[0.18em] text-slate-400" %>
        <%= text_field_tag "search_profile[technology_intent]", simple_input["technology_intent"], id: "search_profile_technology_intent", class: "mt-2 w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white", placeholder: "Java, ServiceNow, .NET, Salesforce, Ruby on Rails..." %>
      </div>
    </div>

    <div class="grid gap-4 md:grid-cols-3">
      <div>
        <%= label_tag "search_profile_seniority_preset", "Senioridade", class: "text-xs font-semibold uppercase tracking-[0.18em] text-slate-400" %>
        <%= select_tag "search_profile[seniority_preset]", options_for_select(SearchProfile::SENIORITY_PRESET_LABELS.map { |value, label| [ label, value ] }, simple_input["seniority_preset"]), id: "search_profile_seniority_preset", class: "mt-2 w-full rounded-2xl border border-white/10 bg-slate-950 px-4 py-3 text-sm text-white" %>
      </div>
      <div>
        <%= form.label :language_scope, "Idioma dos titulos", class: "text-xs font-semibold uppercase tracking-[0.18em] text-slate-400" %>
        <%= form.select :language_scope, options_for_select(SearchProfile::LANGUAGE_SCOPE_LABELS.map { |value, label| [ label, value ] }, simple_input["language_scope"]), {}, class: "mt-2 w-full rounded-2xl border border-white/10 bg-slate-950 px-4 py-3 text-sm text-white" %>
      </div>
      <div>
        <%= label_tag "search_profile_region_scope", "Regiao alvo", class: "text-xs font-semibold uppercase tracking-[0.18em] text-slate-400" %>
        <%= select_tag "search_profile[region_scope]", options_for_select(SearchProfile::REGION_SCOPE_LABELS.map { |value, label| [ label, value ] }, simple_input["region_scope"]), id: "search_profile_region_scope", class: "mt-2 w-full rounded-2xl border border-white/10 bg-slate-950 px-4 py-3 text-sm text-white" %>
      </div>
    </div>

    <div class="grid gap-4 md:grid-cols-2">
      <label class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-slate-200">
        <%= form.check_box :required_remote, { checked: ActiveModel::Type::Boolean.new.cast(simple_input["required_remote"]) , class: "h-4 w-4 rounded border-white/20 bg-slate-950 text-sky-400" }, "1", "0" %>
        Exigir remoto
      </label>
      <label class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-slate-200">
        <%= form.check_box :include_women_only, { checked: ActiveModel::Type::Boolean.new.cast(simple_input["include_women_only"]) , class: "h-4 w-4 rounded border-white/20 bg-slate-950 text-sky-400" }, "1", "0" %>
        Incluir vagas exclusivas para mulheres
      </label>
    </div>

    <% unless @intent_compiler_available %>
      <div class="rounded-2xl border border-amber-300/30 bg-amber-400/10 p-4 text-sm text-amber-100">
        <%= @intent_compiler_setup_hint %> O modo avancado continua disponivel abaixo.
      </div>
    <% end %>

    <div class="flex flex-wrap items-center gap-3">
      <% compile_button_class = if @intent_compiler_available
        "rounded-2xl bg-sky-400 px-5 py-3 text-sm font-bold text-slate-950 transition hover:bg-sky-300"
      else
        "rounded-2xl cursor-not-allowed bg-slate-700 px-5 py-3 text-sm font-bold text-slate-400"
      end %>
      <%= form.button "Gerar variacoes", name: "preview_compile", value: "1", **submit_state_submit_options(loading_text: "Gerando...", class: compile_button_class, disabled: !@intent_compiler_available) %>
      <p class="text-sm text-slate-400">Gera stacks canonicas, aliases e titulos mais provaveis para o stack informado.</p>
    </div>
  </section>

  <% if @compiled_preview.present? %>
    <section class="grid gap-4 rounded-[1.75rem] border border-sky-300/20 bg-sky-400/10 p-5">
      <div class="space-y-1">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-100/80">Preview gerado</p>
        <h2 class="text-lg font-bold text-white"><%= @compiled_preview["profile_name_suggestion"] %></h2>
        <p class="text-sm text-sky-100/70">Revise abaixo e salve. Se mudar a intencao, gere novamente.</p>
      </div>

      <div class="grid gap-4 lg:grid-cols-[0.95fr_1.05fr]">
        <div class="space-y-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-300">Stacks canonicas</p>
            <div class="mt-2 flex flex-wrap gap-2">
              <% Array(@compiled_preview["canonical_stacks"]).each do |stack| %>
                <span class="rounded-full border border-white/10 bg-white/10 px-3 py-1 text-xs font-semibold text-white"><%= stack %></span>
              <% end %>
            </div>
          </div>

          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-300">Aliases tecnicos</p>
            <div class="mt-2 space-y-3">
              <% Array(@compiled_preview["stack_aliases"]).each do |entry| %>
                <div>
                  <p class="text-sm font-semibold text-white"><%= entry["canonical_stack"] %></p>
                  <div class="mt-2 flex flex-wrap gap-2">
                    <% Array(entry["aliases"]).each do |alias_term| %>
                      <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-slate-200"><%= alias_term %></span>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </div>

        <div class="grid gap-4 md:grid-cols-2">
          <div class="rounded-2xl border border-white/10 bg-slate-950/60 p-4">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Titulos PT</p>
            <ul class="mt-3 space-y-2 text-sm text-slate-200">
              <% Array(@compiled_preview["title_variants_pt"]).each do |title| %>
                <li><%= title %></li>
              <% end %>
            </ul>
          </div>
          <div class="rounded-2xl border border-white/10 bg-slate-950/60 p-4">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Titulos EN</p>
            <ul class="mt-3 space-y-2 text-sm text-slate-200">
              <% Array(@compiled_preview["title_variants_en"]).each do |title| %>
                <li><%= title %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </section>
  <% end %>

  <details class="rounded-[1.75rem] border border-white/10 bg-white/[0.03] p-5" <%= advanced_open ? "open" : nil %>>
    <summary class="cursor-pointer list-none">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div class="space-y-1">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Modo avancado</p>
          <h2 class="text-xl font-bold text-white">Ajuste manualmente os termos persistidos</h2>
        </div>
        <span class="rounded-full border border-white/10 px-3 py-1 text-xs font-semibold text-slate-300">Override manual</span>
      </div>
    </summary>

    <div class="mt-5 grid gap-5">
      <p class="text-sm text-slate-400">Este bloco continua sendo a fonte de verdade do matcher. Use-o para override fino ou para salvar um perfil sem IA.</p>

      <% if search_profile.persisted? %>
        <label class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-slate-200">
          <%= form.check_box :active, class: "h-4 w-4 rounded border-white/20 bg-slate-950 text-sky-400" %>
          Perfil ativo
        </label>
      <% end %>

      <div>
        <%= form.label :target_stacks_text, "Stacks canonicas", class: "text-xs font-semibold uppercase tracking-[0.18em] text-slate-400" %>
        <%= form.text_area :target_stacks_text, rows: 2, class: "mt-2 w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white" %>
      </div>

      <div>
        <%= form.label :target_titles_text, "Titulos alvo", class: "text-xs font-semibold uppercase tracking-[0.18em] text-slate-400" %>
        <%= form.text_area :target_titles_text, rows: 3, class: "mt-2 w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white" %>
      </div>

      <div class="grid gap-4 md:grid-cols-3">
        <div>
          <%= form.label :seniority_terms_text, "Senioridade", class: "text-xs font-semibold uppercase tracking-[0.18em] text-slate-400" %>
          <%= form.text_area :seniority_terms_text, rows: 3, class: "mt-2 w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white" %>
        </div>
        <div>
          <%= form.label :location_terms_text, "Localidade", class: "text-xs font-semibold uppercase tracking-[0.18em] text-slate-400" %>
          <%= form.text_area :location_terms_text, rows: 3, class: "mt-2 w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white" %>
        </div>
        <div>
          <%= form.label :negative_terms_text, "Termos negativos", class: "text-xs font-semibold uppercase tracking-[0.18em] text-slate-400" %>
          <%= form.text_area :negative_terms_text, rows: 3, class: "mt-2 w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white" %>
        </div>
      </div>

      <div class="flex flex-wrap gap-3">
        <%= form.submit(search_profile.persisted? ? "Salvar perfil" : "Salvar manualmente", **submit_state_submit_options(loading_text: "Salvando...", class: "rounded-2xl bg-sky-400 px-5 py-3 text-sm font-bold text-slate-950 transition hover:bg-sky-300")) %>
        <%= link_to "Cancelar", search_profiles_path, class: "rounded-2xl border border-white/10 px-5 py-3 text-sm font-semibold text-slate-200 transition hover:bg-white/5" %>
      </div>
    </div>
  </details>
<% end %>
